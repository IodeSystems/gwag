    "graphql": "^16.14.0",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
