node_modules/
.vite/

# Track only the placeholder index.html so the //go:embed directive
# in embed.go has something to embed on a fresh clone (Go fails the
# build if the embed pattern matches zero files). `pnpm run build`
# overwrites the placeholder and emits assets/, which stay
# untracked but get baked into the binary at `go build` time.
dist/*
!dist/index.html
*.log
.DS_Store

# Generated by codegen / router plugin. Re-run `pnpm run gen` after
# the schema changes; CI re-runs both before tsc.
# Kept under version control as placeholders so type-checking works
# on a fresh clone; the build pipeline overwrites them.
# (uncomment if you'd rather not track generated artifacts):
# src/api/gateway.ts
# src/routeTree.gen.ts
# schema.graphql
